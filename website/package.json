    "nuxt-auth-utils": "^0.5.20",
    "prisma": "^6.1.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.12.2",
    "nuxt": "^3.14.0",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  }
