<UserControl x:Class="Lodestone.App.Views.DonateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <StackPanel Margin="36,30" MaxWidth="840" HorizontalAlignment="Left">

        <StackPanel Orientation="Horizontal">
            <Border Width="46" Height="46" CornerRadius="12" Background="{StaticResource PinkSoftBrush}">
                <Path Width="24" Height="24" Stretch="Uniform" Stroke="{StaticResource PinkBrush}" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 20s-7-4.7-7-10a4 4 0 0 1 7-2.5A4 4 0 0 1 19 10c0 5.3-7 10-7 10Z" />
            </Border>
            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Lodestone is free — and always will be" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="No ads, no paywalls, no locked features. Donations fund development and hosting." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0" />
            </StackPanel>
        </StackPanel>

        <Border Style="{StaticResource SegmentBar}" HorizontalAlignment="Left" Margin="0,24,0,0">
            <StackPanel Orientation="Horizontal">
                <RadioButton GroupName="Cycle" Style="{StaticResource Segment}" Content="One-time" IsChecked="{Binding DonateCycle, Converter={StaticResource Equals}, ConverterParameter=once, Mode=TwoWay}" />
                <RadioButton GroupName="Cycle" Style="{StaticResource Segment}" Content="Monthly" IsChecked="{Binding DonateCycle, Converter={StaticResource Equals}, ConverterParameter=monthly, Mode=TwoWay}" />
            </StackPanel>
        </Border>

        <ItemsControl ItemsSource="{Binding Tiers}" Margin="0,18,0,0">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="7,10,7,0">
                        <Border CornerRadius="14" Background="{StaticResource CardBgBrush}" Padding="20,22" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Featured}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#FFEAEAEC" />
                                <TextBlock Text="{Binding Tag}" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding AmountLabel}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,14,0,16" />
                                <ItemsControl ItemsSource="{Binding Perks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                                <Path Width="15" Height="15" Margin="0,2,0,0" VerticalAlignment="Top" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.4" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10" />
                                                <TextBlock Text="{Binding}" FontSize="13" Foreground="#FFC2C2C8" TextWrapping="Wrap" Margin="9,0,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="{Binding ButtonLabel}" Style="{StaticResource PrimaryButton}" Margin="0,18,0,0"
                                        Command="{Binding DataContext.DonateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="999" Padding="11,4" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-10,0,0"
                                Visibility="{Binding Featured, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="MOST POPULAR" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource AccentTextBrush}" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Info banner -->
        <Border CornerRadius="11" Background="{StaticResource AccentFaintBrush}" BorderBrush="#335AC26D" BorderThickness="1" Padding="18,15" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal">
                <Path Width="18" Height="18" VerticalAlignment="Top" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18Z M12 8h.01 M11 12h1v4h1" />
                <TextBlock Text="Every feature in Lodestone is free for everyone. Donations are entirely optional and will never gate functionality — supporters just get a few cosmetic perks and our thanks." FontSize="13" Foreground="#FFB6C9BA" TextWrapping="Wrap" Margin="11,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Redeem -->
        <Border Style="{StaticResource Card}" Padding="18,16" Margin="0,18,0,0">
            <StackPanel>
                <TextBlock Text="{Binding SupporterStatusLabel}" FontSize="13.5" Foreground="{StaticResource TextBodyBrush}" TextWrapping="Wrap" />
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}" Text="{Binding RedeemCode, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2" Content="Redeem code" Style="{StaticResource PrimaryButton}" Command="{Binding RedeemCommand}" />
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
