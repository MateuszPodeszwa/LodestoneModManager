<UserControl x:Class="Lodestone.App.Views.ToastHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <ItemsControl ItemsSource="{Binding Toasts}">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Border Background="{StaticResource ToastBgBrush}" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                        CornerRadius="11" Padding="15,13" Margin="0,10,0,0" MinWidth="248" MaxWidth="320">
                    <Border.Effect><DropShadowEffect BlurRadius="34" ShadowDepth="6" Opacity="0.5" Color="Black" /></Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="24" CornerRadius="12" VerticalAlignment="Top">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="error"><Setter Property="Background" Value="{StaticResource DangerSoftBrush}" /></DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="warning"><Setter Property="Background" Value="#24E3B341" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Path Width="13" Height="13" Stretch="Uniform" StrokeThickness="2.4" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Stroke" Value="{StaticResource AccentBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="error"><Setter Property="Stroke" Value="{StaticResource DangerBrush}" /></DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="warning"><Setter Property="Stroke" Value="{StaticResource WarningBrush}" /></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Border>
                        <StackPanel Margin="11,0,0,0">
                            <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Body}" FontSize="12.5" Foreground="#FF9D9DA5" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
