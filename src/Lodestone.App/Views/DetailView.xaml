<UserControl x:Class="Lodestone.App.Views.DetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFont}">
    <Grid Background="#9E08080B">
        <!-- click-outside to close -->
        <Button Command="{Binding CloseCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="Arrow">
            <Button.Template><ControlTemplate TargetType="Button"><Border Background="Transparent" /></ControlTemplate></Button.Template>
        </Button>

        <Border Width="620" MaxHeight="760" Background="{StaticResource ModalBgBrush}" CornerRadius="16"
                BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid>
                        <!-- gallery (real screenshots when available) -->
                        <ScrollViewer Height="150" Margin="16,16,16,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      Visibility="{Binding HasGallery, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding GalleryUrls}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="250" Height="140" CornerRadius="10" Margin="0,0,8,0" ClipToBounds="True" Background="#FF2E2E35">
                                            <Image Source="{Binding}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <!-- gradient placeholders when a project has no gallery -->
                        <UniformGrid Columns="4" Height="120" Margin="16,16,16,0" Visibility="{Binding HasGallery, Converter={StaticResource InvBoolToVis}}">
                            <Border CornerRadius="10" Margin="0,0,5,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#5AC26D" Offset="0" /><GradientStop Color="#232328" Offset="1" /></LinearGradientBrush></Border.Background></Border>
                            <Border CornerRadius="10" Margin="5,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#3A3A42" Offset="0" /><GradientStop Color="#232328" Offset="1" /></LinearGradientBrush></Border.Background></Border>
                            <Border CornerRadius="10" Margin="5,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#5A91C2" Offset="0" /><GradientStop Color="#232328" Offset="1" /></LinearGradientBrush></Border.Background></Border>
                            <Border CornerRadius="10" Margin="5,0,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#2E2E35" Offset="0" /><GradientStop Color="#232328" Offset="1" /></LinearGradientBrush></Border.Background></Border>
                        </UniformGrid>
                        <Button Style="{StaticResource GhostButton}" Command="{Binding CloseCommand}" Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,14,14,0" Background="#59000000" Foreground="#FFE6E6EA">
                            <Path Width="14" Height="14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" Data="M2,2 L12,12 M12,2 L2,12" />
                        </Button>
                    </Grid>

                    <StackPanel Margin="24,20,24,24">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="58" Height="58" CornerRadius="14" ClipToBounds="True" Background="{Binding Name, Converter={StaticResource NameToColor}}">
                                <Grid>
                                    <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontWeight="Bold" FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Image Source="{Binding IconUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"
                                           Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}" />
                                </Grid>
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="21" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding SubtitleLabel}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Border Background="#08FFFFFF" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="11" Padding="16,14" Margin="0,18,0,0">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel><TextBlock Text="{Binding Downloads}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBodyBrush}" /><TextBlock Text="Downloads" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" /></StackPanel>
                                <Border Width="1" Background="#12FFFFFF" Margin="22,0" />
                                <StackPanel><TextBlock Text="{Binding Followers}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBodyBrush}" /><TextBlock Text="Followers" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" /></StackPanel>
                                <Border Width="1" Background="#12FFFFFF" Margin="22,0" />
                                <StackPanel><TextBlock Text="{Binding Latest}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBodyBrush}" /><TextBlock Text="Latest" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" /></StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding Description}" FontSize="14" Foreground="#FFC2C2C8" TextWrapping="Wrap" Margin="0,16,0,0" LineHeight="22" />

                        <ItemsControl ItemsSource="{Binding Chips}" Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0DFFFFFF" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="999" Padding="11,4" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding}" FontSize="11.5" Foreground="{StaticResource TextBodyBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <StackPanel Margin="0,0,30,0"><TextBlock Text="Versions" FontSize="12.5" Foreground="{StaticResource TextMutedBrush}" /><TextBlock Text="{Binding VersionsLabel}" FontSize="12.5" FontWeight="Medium" Foreground="#FFDCDCE0" Margin="0,3,0,0" /></StackPanel>
                            <StackPanel><TextBlock Text="Loaders" FontSize="12.5" Foreground="{StaticResource TextMutedBrush}" /><TextBlock Text="{Binding LoadersLabel}" FontSize="12.5" FontWeight="Medium" Foreground="#FFDCDCE0" Margin="0,3,0,0" /></StackPanel>
                        </StackPanel>

                        <Grid Margin="0,22,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding InstallCommand}" Padding="13" FontSize="15"
                                    Visibility="{Binding CanInstall, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Path Width="17" Height="17" Stretch="Uniform" Stroke="{StaticResource AccentTextBrush}" StrokeThickness="2.1" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M12 4v11 M7 11l5 5 5-5 M5 20h14" />
                                    <TextBlock Text="Install to library" Margin="8,0,0,0" />
                                </StackPanel>
                            </Button>
                            <StackPanel Visibility="{Binding Installing, Converter={StaticResource BoolToVis}}">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Installing…" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBlock Text="{Binding InstallPercentLabel}" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" />
                                </Grid>
                                <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding InstallPercent}" Background="#17FFFFFF" Foreground="{StaticResource AccentBrush}" BorderThickness="0">
                                    <ProgressBar.Template>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                <Grid>
                                                    <Border x:Name="PART_Track" />
                                                    <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="5" Background="{TemplateBinding Foreground}" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </ProgressBar.Template>
                                </ProgressBar>
                            </StackPanel>
                            <Border Background="{StaticResource AccentFaintBrush}" CornerRadius="10" Padding="13" Visibility="{Binding Installed, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Path Width="17" Height="17" Stretch="Uniform" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.4" StrokeLineJoin="Round" StrokeStartLineCap="Round" Data="M5 12l4 4 10-10" />
                                    <TextBlock Text="Installed" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="8,0,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
